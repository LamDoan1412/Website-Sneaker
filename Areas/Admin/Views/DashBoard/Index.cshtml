@using LydShop.Models
@{
    ViewData["Title"] = "Admin Dashboard";
    var recentOrders = ViewBag.RecentOrders as List<Order>;
    var topProducts = ViewBag.TopProducts as IEnumerable<dynamic>;
}

<div class="container-fluid py-4 animate-fade-in">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="fw-800 text-light-dark h3 mb-1">Tổng quan Dashboard</h1>
            <p class="text-muted fs-7 mb-0">Hệ thống quản lý cửa hàng giày LydShop</p>
        </div>
        <div class="d-flex gap-2">
            <span class="badge bg-primary px-3 py-2 rounded-pill fs-7 d-flex align-items-center">
                <i class="far fa-calendar-alt me-2"></i>Tháng @DateTime.Now.ToString("MM/yyyy")
            </span>
        </div>
    </div>

    <!-- Stat Cards Row -->
    <div class="row g-4 mb-4">
        <!-- Revenue Card -->
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm admin-stat-card p-3 rounded-4 glass-card border-start border-primary border-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted fs-8 fw-600 text-uppercase tracking-wider">Doanh thu tháng này</span>
                        <h3 class="fw-800 text-dark mt-1 mb-0">@ViewBag.MonthRevenue.ToString("N0") đ</h3>
                    </div>
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fas fa-hand-holding-usd fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Revenue Card -->
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm admin-stat-card p-3 rounded-4 glass-card border-start border-success border-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted fs-8 fw-600 text-uppercase tracking-wider">Tổng doanh thu thực tế</span>
                        <h3 class="fw-800 text-dark mt-1 mb-0">@ViewBag.TotalRevenue.ToString("N0") đ</h3>
                    </div>
                    <div class="stat-icon bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fas fa-wallet fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Orders Card -->
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm admin-stat-card p-3 rounded-4 glass-card border-start border-warning border-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted fs-8 fw-600 text-uppercase tracking-wider">Đơn hàng mới</span>
                        <h3 class="fw-800 text-dark mt-1 mb-0">@ViewBag.PendingOrders / @ViewBag.TotalOrders</h3>
                    </div>
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fas fa-shopping-cart fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Users Card -->
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm admin-stat-card p-3 rounded-4 glass-card border-start border-info border-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-muted fs-8 fw-600 text-uppercase tracking-wider">Khách hàng</span>
                        <h3 class="fw-800 text-dark mt-1 mb-0">@ViewBag.TotalUsers</h3>
                    </div>
                    <div class="stat-icon bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <i class="fas fa-users fa-lg"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="row g-4 mb-4">
        <!-- Recent Orders -->
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm p-4 rounded-4 glass-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-800 text-light-dark mb-0"><i class="fas fa-clock me-2 text-primary"></i>Đơn hàng gần đây</h5>
                    <a href="/Admin/Order" class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-600 fs-8">Xem tất cả</a>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle custom-table mb-0 fs-7">
                        <thead>
                            <tr class="text-muted border-bottom border-light-subtle fw-600">
                                <th scope="col">Mã đơn</th>
                                <th scope="col">Khách hàng</th>
                                <th scope="col">Tổng tiền</th>
                                <th scope="col">Trạng thái</th>
                                <th scope="col">Ngày đặt</th>
                                <th scope="col" class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (recentOrders == null || !recentOrders.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">Chưa có đơn hàng nào.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var order in recentOrders)
                                {
                                    var badgeClass = order.Status switch
                                    {
                                        OrderStatus.Pending => "bg-warning-subtle text-warning border-warning-subtle",
                                        OrderStatus.Confirmed => "bg-info-subtle text-info border-info-subtle",
                                        OrderStatus.Shipping => "bg-primary-subtle text-primary border-primary-subtle",
                                        OrderStatus.Delivered => "bg-success-subtle text-success border-success-subtle",
                                        OrderStatus.Cancelled => "bg-danger-subtle text-danger border-danger-subtle",
                                        _ => "bg-secondary-subtle text-secondary"
                                    };

                                    var statusText = order.Status switch
                                    {
                                        OrderStatus.Pending => "Chờ xác nhận",
                                        OrderStatus.Confirmed => "Đã xác nhận",
                                        OrderStatus.Shipping => "Đang giao",
                                        OrderStatus.Delivered => "Đã giao",
                                        OrderStatus.Cancelled => "Đã hủy",
                                        _ => "Không rõ"
                                    };

                                    <tr>
                                        <td><strong class="text-dark">@order.OrderCode</strong></td>
                                        <td class="fw-600 text-dark">@order.ReceiverName</td>
                                        <td class="fw-700 text-primary">@order.TotalAmount.ToString("N0") đ</td>
                                        <td>
                                            <span class="badge px-2 py-1 rounded-pill fs-9 border @badgeClass">
                                                @statusText
                                            </span>
                                        </td>
                                        <td class="text-muted">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-center">
                                            <a href="/Admin/Order/Details/@order.Id" class="btn btn-outline-primary btn-sm rounded-circle p-1" title="Chi tiết">
                                                <i class="fas fa-eye fs-8"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Top Selling Products -->
        <div class="col-xl-4">
            <div class="card border-0 shadow-sm p-4 rounded-4 glass-card h-100">
                <h5 class="fw-800 text-light-dark mb-4"><i class="fas fa-fire me-2 text-warning"></i>Sản phẩm bán chạy</h5>
                
                <div class="d-flex flex-column gap-3">
                    @if (topProducts == null || !topProducts.Any())
                    {
                        <p class="text-center text-muted py-5 my-0 fs-7">Chưa có dữ liệu bán chạy.</p>
                    }
                    else
                    {
                        int rank = 1;
                        foreach (var item in topProducts)
                        {
                            <div class="d-flex align-items-center justify-content-between p-3 border border-light-subtle rounded-3 bg-light bg-opacity-50">
                                <div class="d-flex align-items-center gap-3 limit-1-line" style="max-width: 80%;">
                                    <span class="badge bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 25px; height: 25px; font-size: 0.8rem;">
                                        @rank
                                    </span>
                                    <h6 class="fw-700 fs-7 text-dark mb-0 limit-1-line">@item.ProductName</h6>
                                </div>
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded-pill fs-8 fw-700 text-nowrap">
                                    Đã bán: @item.TotalSold
                                </span>
                            </div>
                            rank++;
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
