@model List<LydShop.Models.Order>
@using LydShop.Models
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    int curPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    OrderStatus? filterStatus = ViewBag.Status;
}

<div class="container-fluid py-4 animate-fade-in">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="fw-800 text-light-dark h3 mb-1">Quản lý Đơn hàng</h1>
            <p class="text-muted fs-7 mb-0">Theo dõi và xử lý tất cả đơn hàng của cửa hàng</p>
        </div>
    </div>

    <!-- Filter + Search -->
    <div class="card border-0 shadow-sm p-3 rounded-4 glass-card mb-4">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">

            <!-- Status tabs -->
            <div class="col-12 d-flex gap-2 flex-wrap mb-1">
                <a href="@Url.Action("Index")"
                   class="btn btn-sm rounded-pill fw-600 @(filterStatus == null ? "btn-dark" : "btn-outline-secondary")">
                    Tất cả
                </a>
                @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
                {
                    var label = s switch
                    {
                        OrderStatus.Pending => "⏳ Chờ xác nhận",
                        OrderStatus.Confirmed => "✅ Đã xác nhận",
                        OrderStatus.Shipping => "🚚 Đang giao",
                        OrderStatus.Delivered => "✓ Đã giao",
                        OrderStatus.Cancelled => "✗ Đã huỷ",
                        _ => s.ToString()
                    };
                    <a href="@Url.Action("Index", new { status = s, search = ViewBag.Search })"
                       class="btn btn-sm rounded-pill fw-600 @(filterStatus == s ? "btn-dark" : "btn-outline-secondary")">
                        @label
                    </a>
                }
            </div>

            <!-- Search -->
            <div class="col-md-9">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0 text-muted">
                        <i class="fas fa-search"></i>
                    </span>
                    <input type="text" name="search" value="@ViewBag.Search"
                           class="form-control bg-light border-0 shadow-none fs-7"
                           placeholder="Tìm mã đơn, tên KH, SĐT..." />
                    @if (filterStatus != null)
                    {
                        <input type="hidden" name="status" value="@((int)filterStatus)" />
                    }
                </div>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 fw-600 fs-7 rounded-3">
                    Tìm kiếm <i class="fas fa-search ms-1"></i>
                </button>
            </div>
        </form>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm p-4 rounded-4 glass-card">
        <div class="table-responsive">
            <table class="table align-middle custom-table mb-0 fs-7">
                <thead>
                    <tr class="text-muted border-bottom fw-600">
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>SĐT</th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="text-center">Trạng thái</th>
                        <th>Ngày đặt</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fas fa-box-open fa-2x mb-2 d-block opacity-25"></i>
                                Không có đơn hàng nào.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var o in Model)
                        {
                            var (badgeClass, statusText) = o.Status switch
                            {
                                OrderStatus.Pending => ("bg-warning-subtle text-warning border-warning-subtle", "Chờ xác nhận"),
                                OrderStatus.Confirmed => ("bg-info-subtle text-info border-info-subtle", "Đã xác nhận"),
                                OrderStatus.Shipping => ("bg-primary-subtle text-primary border-primary-subtle", "Đang giao"),
                                OrderStatus.Delivered => ("bg-success-subtle text-success border-success-subtle", "Đã giao"),
                                OrderStatus.Cancelled => ("bg-danger-subtle text-danger border-danger-subtle", "Đã huỷ"),
                                _ => ("bg-secondary-subtle text-secondary", o.Status.ToString())
                            };
                            <tr>
                                <td>
                                    <strong class="text-dark">@o.OrderCode</strong>
                                </td>
                                <td class="fw-600 text-dark">@o.ReceiverName</td>
                                <td class="text-muted">@o.ReceiverPhone</td>
                                <td class="text-end fw-700 text-primary">
                                    @o.TotalAmount.ToString("N0") đ
                                </td>
                                <td class="text-center">
                                    <span class="badge px-2 py-1 rounded-pill fs-9 border @badgeClass">
                                        @statusText
                                    </span>
                                </td>
                                <td class="text-muted">
                                    @o.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="text-center">
                                    <a asp-action="Detail" asp-route-id="@o.Id"
                                       class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-600">
                                        <i class="fas fa-eye me-1 fs-8"></i>Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-center gap-2 mt-4">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a href="@Url.Action("Index", new { page = i, status = filterStatus, search = ViewBag.Search })"
                       class="btn btn-sm rounded-pill @(i == curPage ? "btn-dark" : "btn-outline-secondary")">
                        @i
                    </a>
                }
            </div>
        }
    </div>
</div>
