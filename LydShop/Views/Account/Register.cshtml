@* Views/Account/Register.cshtml *@
@model LydShop.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
.auth-wrap { min-height: calc(100vh - 62px); display: grid; grid-template-columns: 1fr 1fr; }
.auth-left {
    background: linear-gradient(145deg, #0c0c0c 0%, #1c0a00 100%);
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    padding: 60px; color: white;
}
.auth-brand { font-size: 3.2rem; font-weight: 800; letter-spacing: -2px; }
.auth-brand span { color: #e8500a; }
.auth-right {
    display: flex; flex-direction: column;
    justify-content: center;
    padding: 50px 80px;
    background: #faf9f7;
    overflow-y: auto;
}
.auth-title { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 4px; }
.auth-sub { font-size: 13.5px; color: #aaa; margin-bottom: 28px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.form-group { margin-bottom: 16px; }
.form-label { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #aaa; margin-bottom: 8px; display: block; }
.form-ctrl {
    width: 100%; padding: 12px 16px;
    border: 1.5px solid #e8e4de; border-radius: 10px;
    font-family: 'Inter', sans-serif; font-size: 14px;
    background: white; outline: none;
    transition: border-color .18s;
}
.form-ctrl:focus { border-color: #e8500a; }
.field-err { color: #ef4444; font-size: 11px; margin-top: 4px; display: block; }
.btn-auth {
    width: 100%; height: 52px;
    background: #e8500a; color: white; border: none;
    border-radius: 11px;
    font-family: 'Inter', sans-serif;
    font-size: 15px; font-weight: 700;
    cursor: pointer; transition: background .18s;
    margin-top: 6px;
}
.btn-auth:hover { background: #ff6b2b; }
.auth-switch { text-align: center; margin-top: 18px; font-size: 13.5px; color: #aaa; }
.auth-switch a { color: #e8500a; text-decoration: none; font-weight: 700; }
.error-box { background: #fff0f0; border: 1px solid #fca5a5; color: #ef4444; padding: 11px 14px; border-radius: 9px; font-size: 13px; margin-bottom: 16px; }
@@media (max-width: 768px) {
    .auth-wrap { grid-template-columns: 1fr; }
    .auth-left { display: none; }
    .auth-right { padding: 40px 24px; }
    .form-row { grid-template-columns: 1fr; }
}
</style>
}

<div class="auth-wrap">
    <div class="auth-left">
        <div class="auth-brand">Lyd<span>Shop</span></div>
        <div style="font-size:12px;color:#555;letter-spacing:2px;margin-top:8px">GIÀY THỂ THAO CHÍNH HÃNG</div>
        <div style="font-size:64px;margin:32px 0">🛍️</div>
        <div style="font-size:13.5px;color:#444;text-align:center;max-width:240px;line-height:1.7">
            Tạo tài khoản để theo dõi đơn hàng và nhận ưu đãi độc quyền
        </div>
    </div>

    <div class="auth-right">
        <h2 class="auth-title">Đăng ký</h2>
        <p class="auth-sub">Tạo tài khoản hoàn toàn miễn phí</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div class="error-box">⚠ @err.ErrorMessage</div>
            }
        }

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Họ và tên *</label>
                <input asp-for="FullName" class="form-ctrl" placeholder="Nguyễn Văn A" />
                <span asp-validation-for="FullName" class="field-err"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Email *</label>
                    <input asp-for="Email" class="form-ctrl" placeholder="email@example.com" />
                    <span asp-validation-for="Email" class="field-err"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="Phone" class="form-ctrl" placeholder="0912 345 678" />
                    <span asp-validation-for="Phone" class="field-err"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Mật khẩu *</label>
                    <input asp-for="Password" class="form-ctrl" placeholder="Ít nhất 6 ký tự" />
                    <span asp-validation-for="Password" class="field-err"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Xác nhận mật khẩu *</label>
                    <input asp-for="ConfirmPassword" class="form-ctrl" placeholder="Nhập lại mật khẩu" />
                    <span asp-validation-for="ConfirmPassword" class="field-err"></span>
                </div>
            </div>

            <button type="submit" class="btn-auth">Tạo tài khoản →</button>
        </form>

        <div class="auth-switch">
            Đã có tài khoản? <a asp-action="Login">Đăng nhập</a>
        </div>
    </div>
</div>
