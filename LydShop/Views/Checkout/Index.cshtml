@* Views/Checkout/Index.cshtml *@
@model LydShop.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

@section Styles {
<style>
.checkout-page { max-width: 1100px; margin: 40px auto; padding: 0 40px 60px; }
.page-title { font-size: 2rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 28px; }
.page-title span { color: #e8500a; }
.checkout-layout { display: grid; grid-template-columns: 1fr 360px; gap: 28px; }

/* CARDS */
.form-card {
    background: white;
    border-radius: 14px;
    border: 1px solid #ede9e2;
    padding: 26px 28px;
    margin-bottom: 20px;
}
.card-title {
    font-size: 15px; font-weight: 800;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid #f5f2ee;
    display: flex; align-items: center; gap: 8px;
}
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-group { margin-bottom: 16px; }
.form-label {
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: #aaa; margin-bottom: 8px; display: block;
}
.form-ctrl {
    width: 100%; padding: 11px 14px;
    border: 1.5px solid #e8e4de; border-radius: 10px;
    font-family: 'Inter', sans-serif; font-size: 14px;
    background: white; outline: none;
    transition: border-color .18s;
}
.form-ctrl:focus { border-color: #e8500a; }
textarea.form-ctrl { resize: vertical; min-height: 80px; }
.field-error { color: #ef4444; font-size: 12px; margin-top: 4px; }

/* PAYMENT OPTIONS */
.payment-opts { display: flex; flex-direction: column; gap: 10px; }
.pay-opt {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 16px;
    border: 1.5px solid #e8e4de;
    border-radius: 10px;
    cursor: pointer;
    transition: border-color .18s, background .18s;
}
.pay-opt:has(input:checked) {
    border-color: #e8500a;
    background: #fff8f5;
}
.pay-opt input[type=radio] { accent-color: #e8500a; width: 16px; height: 16px; }
.pay-icon { font-size: 24px; }
.pay-name { font-weight: 700; font-size: 14px; }
.pay-desc { font-size: 12px; color: #aaa; }

/* SUMMARY */
.order-summary {
    background: white;
    border-radius: 14px;
    border: 1px solid #ede9e2;
    padding: 24px;
    position: sticky; top: 80px; align-self: start;
}
.sum-head { font-weight: 800; font-size: 1rem; margin-bottom: 16px; padding-bottom: 14px; border-bottom: 1px solid #f5f2ee; }
.order-item { display: flex; gap: 12px; align-items: center; margin-bottom: 14px; }
.order-thumb { width: 56px; height: 56px; border-radius: 8px; overflow: hidden; background: #f5f2ee; flex-shrink: 0; }
.order-thumb img { width: 100%; height: 100%; object-fit: cover; }
.order-item-name { font-size: 13px; font-weight: 600; color: #111; }
.order-item-meta { font-size: 11px; color: #aaa; margin-top: 2px; }
.order-item-price { margin-left: auto; font-weight: 700; color: #e8500a; font-size: 13.5px; white-space: nowrap; }

.sum-divider { height: 1px; background: #f5f2ee; margin: 14px 0; }
.sum-row { display: flex; justify-content: space-between; font-size: 13.5px; margin-bottom: 10px; color: #666; }
.sum-row.total { font-size: 17px; font-weight: 800; color: #111; border-top: 1px solid #f0ede8; padding-top: 12px; margin-top: 4px; }
.sum-row.total span:last-child { color: #e8500a; }
.btn-place {
    width: 100%; height: 52px;
    background: #e8500a; color: white; border: none;
    border-radius: 11px;
    font-family: 'Inter', sans-serif;
    font-size: 15px; font-weight: 700;
    cursor: pointer; transition: background .18s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    margin-top: 16px;
}
.btn-place:hover { background: #ff6b2b; }
.security-note { text-align: center; font-size: 11px; color: #bbb; margin-top: 10px; }

@@media (max-width: 900px) {
    .checkout-layout { grid-template-columns: 1fr; }
    .order-summary { position: static; }
    .checkout-page { padding: 0 16px 40px; }
    .form-row { grid-template-columns: 1fr; }
}
</style>
}

<div class="checkout-page">
    <h1 class="page-title">THANH <span>TOÁN</span></h1>

    <form asp-action="PlaceOrder" method="post">
        @Html.AntiForgeryToken()
        <div class="checkout-layout">

            <!-- LEFT -->
            <div>
                <!-- Thông tin giao hàng -->
                <div class="form-card">
                    <div class="card-title">📦 Thông tin giao hàng</div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Tên người nhận *</label>
                            <input asp-for="ReceiverName" class="form-ctrl"
                                   placeholder="Nguyễn Văn A" />
                            <span asp-validation-for="ReceiverName" class="field-error"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Số điện thoại *</label>
                            <input asp-for="ReceiverPhone" class="form-ctrl"
                                   placeholder="0912 345 678" />
                            <span asp-validation-for="ReceiverPhone" class="field-error"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Địa chỉ giao hàng *</label>
                        <input asp-for="ShippingAddress" class="form-ctrl"
                               placeholder="Số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố" />
                        <span asp-validation-for="ShippingAddress" class="field-error"></span>
                    </div>

                    <div class="form-group" style="margin-bottom:0">
                        <label class="form-label">Ghi chú</label>
                        <textarea asp-for="Note" class="form-ctrl"
                                  placeholder="Ghi chú thêm (thời gian giao hàng, yêu cầu đặc biệt...)"></textarea>
                    </div>
                </div>

                <!-- Phương thức thanh toán -->
                <div class="form-card">
                    <div class="card-title">💳 Phương thức thanh toán</div>
                    <div class="payment-opts">
                        <label class="pay-opt">
                            <input type="radio" asp-for="PaymentMethod"
                                   value="COD" checked />
                            <span class="pay-icon">💵</span>
                            <div>
                                <div class="pay-name">Thanh toán khi nhận hàng (COD)</div>
                                <div class="pay-desc">Trả tiền mặt khi nhận hàng tại nhà</div>
                            </div>
                        </label>
                        <label class="pay-opt">
                            <input type="radio" asp-for="PaymentMethod"
                                   value="BankTransfer" />
                            <span class="pay-icon">🏦</span>
                            <div>
                                <div class="pay-name">Chuyển khoản ngân hàng</div>
                                <div class="pay-desc">MB Bank · Vietcombank · Techcombank</div>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Order summary -->
            <div class="order-summary">
                <div class="sum-head">📋 Đơn hàng của bạn</div>

                @foreach (var item in Model.CartItems)
                {
                    <div class="order-item">
                        <div class="order-thumb">
                            <img src="@(string.IsNullOrEmpty(item.ProductImage) ? "/images/no-image.png" : item.ProductImage)"
                                 alt="@item.ProductName" />
                        </div>
                        <div style="flex:1;min-width:0">
                            <div class="order-item-name">@item.ProductName</div>
                            <div class="order-item-meta">
                                @if (!string.IsNullOrEmpty(item.Size))
                                { <text>Size @item.Size</text> }
                                @if (!string.IsNullOrEmpty(item.Color))
                                { <text> · @item.Color</text> }
                                · SL: @item.Quantity
                            </div>
                        </div>
                        <div class="order-item-price">@item.TotalPrice.ToString("N0") ₫</div>
                    </div>
                }

                <div class="sum-divider"></div>

                <div class="sum-row">
                    <span>Tạm tính</span>
                    <span>@Model.ItemsTotal.ToString("N0") ₫</span>
                </div>
                <div class="sum-row">
                    <span>Vận chuyển</span>
                    <span>@(Model.ShippingFee == 0 ? "Miễn phí" : Model.ShippingFee.ToString("N0") + " ₫")</span>
                </div>
                <div class="sum-row total">
                    <span>Tổng cộng</span>
                    <span>@Model.GrandTotal.ToString("N0") ₫</span>
                </div>

                <button type="submit" class="btn-place">
                    <i class="fas fa-lock"></i> Đặt hàng ngay
                </button>
                <div class="security-note">🔒 Thông tin được mã hoá và bảo mật</div>
            </div>

        </div>
    </form>
</div>
