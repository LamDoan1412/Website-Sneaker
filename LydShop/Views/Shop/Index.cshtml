@* Views/Shop/Index.cshtml *@
@model List<LydShop.Models.Product>
@{
    ViewData["Title"] = "Tất cả sản phẩm";
    int curPage   = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

@section Styles {
<style>
/* ── HERO ── */
.shop-hero {
    background: linear-gradient(135deg, #0c0c0c 0%, #1c0a00 100%);
    padding: 52px 60px;
    color: white;
}
.shop-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: 1.05;
    margin: 0;
}
.shop-hero h1 span { color: #e8500a; }

/* ── LAYOUT ── */
.shop-body {
    max-width: 1380px;
    margin: 0 auto;
    padding: 32px 40px 60px;
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 32px;
    align-items: start;
}

/* ── SIDEBAR ── */
.filter-sidebar {
    background: white;
    border-radius: 14px;
    border: 1px solid #ede9e2;
    padding: 24px;
    position: sticky;
    top: 78px;
}
.filter-sidebar h6 {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 12px;
}
.filter-option {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 7px 10px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13.5px;
    color: #444;
    transition: background .15s;
    text-decoration: none;
}
.filter-option:hover { background: #f5f2ee; color: #222; }
.filter-option.active { background: #fff3ee; color: #e8500a; font-weight: 600; }
.filter-option input[type=radio] { accent-color: #e8500a; }
.filter-divider { height: 1px; background: #f0ede8; margin: 16px 0; }
.price-inputs { display: flex; flex-direction: column; gap: 8px; }
.price-input {
    border: 1.5px solid #e8e4de;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    width: 100%;
    outline: none;
}
.price-input:focus { border-color: #e8500a; }
.btn-apply {
    width: 100%;
    background: #e8500a;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 9px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
    transition: background .18s;
}
.btn-apply:hover { background: #ff6b2b; }

/* ── TOOLBAR ── */
.toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    gap: 12px;
}
.result-count { font-size: 13px; color: #888; }
.sort-select {
    border: 1.5px solid #e8e4de;
    border-radius: 8px;
    padding: 7px 12px;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    background: white;
    cursor: pointer;
    outline: none;
}

/* ── PRODUCT GRID ── */
.product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 20px;
}
.product-card {
    background: white;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #ede9e2;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform .2s, box-shadow .2s;
}
.product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,.09);
}
.card-img-wrap {
    aspect-ratio: 1;
    background: #f5f2ee;
    overflow: hidden;
    position: relative;
}
.card-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .35s;
}
.product-card:hover .card-img-wrap img { transform: scale(1.06); }
.badge-sale {
    position: absolute;
    top: 10px; left: 10px;
    background: #e8500a;
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 5px;
    letter-spacing: 0.5px;
}
.badge-featured {
    position: absolute;
    top: 10px; right: 10px;
    background: #111;
    color: #ffd60a;
    font-size: 10px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 5px;
}
.card-body-inner { padding: 14px 16px 16px; }
.card-brand {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #e8500a;
    margin-bottom: 4px;
}
.card-name {
    font-size: 14px;
    font-weight: 700;
    color: #111;
    margin-bottom: 6px;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.card-rating {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: #888;
    margin-bottom: 8px;
}
.stars { color: #f5a623; letter-spacing: 1px; font-size: 11px; }
.card-price { display: flex; align-items: baseline; gap: 8px; }
.price-current { font-size: 16px; font-weight: 700; color: #e8500a; }
.price-original { font-size: 12px; color: #bbb; text-decoration: line-through; }
.card-stock { font-size: 11px; margin-top: 6px; }
.in-stock  { color: #22c55e; }
.out-stock { color: #ef4444; }

/* ── PAGINATION ── */
.pagination-wrap {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 36px;
}
.page-btn {
    width: 38px; height: 38px;
    border-radius: 8px;
    border: 1.5px solid #e8e4de;
    background: white;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px;
    cursor: pointer;
    text-decoration: none;
    color: #444;
    transition: all .18s;
}
.page-btn:hover, .page-btn.active {
    background: #e8500a;
    border-color: #e8500a;
    color: white;
}
.empty-state { text-align: center; padding: 80px 20px; }
.empty-state .empty-icon { font-size: 56px; margin-bottom: 16px; }

@@media (max-width: 900px) {
    .shop-body { grid-template-columns: 1fr; padding: 20px 16px; }
    .filter-sidebar { position: static; }
    .shop-hero { padding: 40px 20px; }
}
</style>
}

<!-- Hero -->
<div class="shop-hero">
    <h1>GIÀY THỂ THAO<br><span>CHÍNH HÃNG</span></h1>
</div>

<div class="shop-body">

    <!-- ── SIDEBAR ── -->
    <aside class="filter-sidebar">
        <form method="get" asp-action="Index" id="filterForm">

            <!-- Danh mục -->
            <h6>Danh mục</h6>
            <label class="filter-option @(ViewBag.CategoryId == null ? "active" : "")">
                <input type="radio" name="categoryId" value=""
                       @(ViewBag.CategoryId == null ? "checked" : "")
                       onchange="document.getElementById('filterForm').submit()" />
                Tất cả sản phẩm
            </label>
            @foreach (var cat in (List<LydShop.Models.Category>)ViewBag.Categories)
            {
                <label class="filter-option @((int?)ViewBag.CategoryId == cat.Id ? "active" : "")">
                    <input type="radio" name="categoryId" value="@cat.Id"
                           @((int?)ViewBag.CategoryId == cat.Id ? "checked" : "")
                           onchange="document.getElementById('filterForm').submit()" />
                    @cat.Name
                </label>
            }

            <div class="filter-divider"></div>

            <!-- Thương hiệu -->
            <h6>Thương hiệu</h6>
            <label class="filter-option @(ViewBag.Brand == null ? "active" : "")">
                <input type="radio" name="brand" value=""
                       @(ViewBag.Brand == null ? "checked" : "")
                       onchange="document.getElementById('filterForm').submit()" />
                Tất cả thương hiệu
            </label>
            @foreach (var brand in (List<string>)ViewBag.Brands)
            {
                <label class="filter-option @(ViewBag.Brand == brand ? "active" : "")">
                    <input type="radio" name="brand" value="@brand"
                           @(ViewBag.Brand == brand ? "checked" : "")
                           onchange="document.getElementById('filterForm').submit()" />
                    @brand
                </label>
            }

            <div class="filter-divider"></div>

            <!-- Giá -->
            <h6>Khoảng giá (VND)</h6>
            <div class="price-inputs">
                <input type="number" class="price-input" name="minPrice"
                       value="@ViewBag.MinPrice" placeholder="Từ" />
                <input type="number" class="price-input" name="maxPrice"
                       value="@ViewBag.MaxPrice" placeholder="Đến" />
            </div>
            <button type="submit" class="btn-apply">Áp dụng</button>

            <!-- Giữ lại các filter khác -->
            @if (ViewBag.Search != null)
            { <input type="hidden" name="search" value="@ViewBag.Search" /> }
            @if (ViewBag.Sort != null)
            { <input type="hidden" name="sort" value="@ViewBag.Sort" /> }

        </form>
    </aside>

    <!-- ── MAIN ── -->
    <div>
        <!-- Toolbar -->
        <div class="toolbar">
            <span class="result-count">
                Tìm thấy <strong>@ViewBag.TotalItems</strong> sản phẩm
            </span>
            <form method="get" asp-action="Index" style="display:flex;align-items:center;gap:8px">
                @if (ViewBag.CategoryId != null)
                { <input type="hidden" name="categoryId" value="@ViewBag.CategoryId" /> }
                @if (ViewBag.Brand != null)
                { <input type="hidden" name="brand" value="@ViewBag.Brand" /> }
                @if (ViewBag.Search != null)
                { <input type="hidden" name="search" value="@ViewBag.Search" /> }
                <span style="font-size:13px;color:#888">Sắp xếp:</span>
                <select class="sort-select" name="sort" onchange="this.form.submit()">
                    <option value="" selected="@(ViewBag.Sort == null)">Mặc định</option>
                    <option value="newest" selected="@(ViewBag.Sort == "newest")">Mới nhất</option>
                    <option value="price_asc" selected="@(ViewBag.Sort == "price_asc")">Giá tăng dần</option>
                    <option value="price_desc" selected="@(ViewBag.Sort == "price_desc")">Giá giảm dần</option>
                </select>
            </form>
        </div>

        <!-- Grid -->
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">👟</div>
                <h5 style="font-weight:700">Không tìm thấy sản phẩm</h5>
                <p style="color:#999;margin:8px 0 20px">Thử thay đổi bộ lọc hoặc tìm kiếm khác</p>
                <a asp-action="Index" style="color:#e8500a;font-weight:600;text-decoration:none">
                    ← Xem tất cả sản phẩm
                </a>
            </div>
        }
        else
        {
            <div class="product-grid">
                @foreach (var p in Model)
                {
                    <a class="product-card" asp-action="Detail" asp-route-id="@p.Id">
                        <div class="card-img-wrap">
                            <img src="@(p.ImageUrl ?? "/images/no-image.png")"
                                 alt="@p.Name" loading="lazy" />
                            @if (p.SalePrice.HasValue && p.SalePrice > 0)
                            {
                                var disc = (int)Math.Round((1 - p.SalePrice.Value / p.Price) * 100);
                                <span class="badge-sale">-@disc%</span>
                            }
                            @if (p.IsFeatured)
                            {
                                <span class="badge-featured">⭐ Nổi bật</span>
                            }
                        </div>
                        <div class="card-body-inner">
                            <div class="card-brand">@p.Brand</div>
                            <div class="card-name">@p.Name</div>
                            @if (p.Reviews.Any())
                            {
                                <div class="card-rating">
                                    <span class="stars">
                                        @for (int i = 1; i <= 5; i++)
                                        { @(i <= Math.Round(p.AverageRating) ? "★" : "☆") }
                                    </span>
                                    <span>(@p.Reviews.Count)</span>
                                </div>
                            }
                            <div class="card-price">
                                <span class="price-current">
                                    @p.CurrentPrice.ToString("N0") ₫
                                </span>
                                @if (p.SalePrice.HasValue && p.SalePrice > 0)
                                {
                                    <span class="price-original">@p.Price.ToString("N0") ₫</span>
                                }
                            </div>
                            <div class="card-stock">
                                @if (p.Stock > 0)
                                { <span class="in-stock">● Còn hàng (@p.Stock đôi)</span> }
                                else
                                { <span class="out-stock">● Hết hàng</span> }
                            </div>
                        </div>
                    </a>
                }
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="pagination-wrap">
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <a class="page-btn @(i == curPage ? "active" : "")"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-categoryId="@ViewBag.CategoryId"
                           asp-route-brand="@ViewBag.Brand"
                           asp-route-search="@ViewBag.Search"
                           asp-route-sort="@ViewBag.Sort">
                            @i
                        </a>
                    }
                </div>
            }
        }
    </div>
</div>
