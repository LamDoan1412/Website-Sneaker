@{
    ViewData["Title"] = "Từ Chối Truy Cập";
}

<div class="container my-5 text-center py-5 animate-fade-in">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg glass-card p-5">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="fas fa-exclamation-triangle fa-5x text-danger animate-pulse"></i>
                    </div>
                    <h2 class="fw-800 text-light-dark mb-3">Từ Chối Truy Cập</h2>
                    <p class="text-muted mb-4 fs-5">
                        Xin lỗi, bạn không có quyền truy cập vào trang này. Trang này chỉ dành cho quản trị viên hoặc các tài khoản có phân quyền cao hơn.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="/" class="btn btn-primary px-4 py-3 rounded-pill fw-600 shadow-sm-primary btn-hover-scale">
                            <i class="fas fa-home me-2"></i>Trang Chủ
                        </a>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 py-3 rounded-pill fw-600 btn-hover-scale">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
