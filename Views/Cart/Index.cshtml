@* Views/Cart/Index.cshtml *@
@model LydShop.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

@section Styles {
<style>
.cart-page { max-width: 1100px; margin: 40px auto; padding: 0 40px 60px; }
.page-title { font-size: 2rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 28px; }
.page-title span { color: #e8500a; }

.cart-layout { display: grid; grid-template-columns: 1fr 340px; gap: 28px; }

/* TABLE */
.cart-table { background: white; border-radius: 14px; border: 1px solid #ede9e2; overflow: hidden; }
.cart-row {
    display: grid;
    grid-template-columns: 88px 1fr auto auto auto;
    align-items: center;
    gap: 16px;
    padding: 18px 22px;
    border-bottom: 1px solid #f5f2ee;
}
.cart-row:last-child { border-bottom: none; }
.cart-thumb {
    width: 88px; height: 88px;
    border-radius: 10px;
    overflow: hidden;
    background: #f5f2ee;
    flex-shrink: 0;
}
.cart-thumb img { width: 100%; height: 100%; object-fit: cover; }
.item-name { font-weight: 700; font-size: 14px; color: #111; margin-bottom: 4px; }
.item-meta { display: flex; gap: 8px; flex-wrap: wrap; }
.item-tag {
    background: #f5f2ee;
    color: #666;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 5px;
}
.item-unit { font-size: 12px; color: #bbb; margin-top: 4px; }

/* QTY CTRL */
.qty-ctrl { display: flex; align-items: center; }
.qc-btn {
    width: 32px; height: 32px;
    border: 1.5px solid #e8e4de;
    background: white;
    font-size: 16px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .15s;
    font-family: 'Inter', sans-serif;
}
.qc-btn:first-child { border-radius: 7px 0 0 7px; }
.qc-btn:last-child  { border-radius: 0 7px 7px 0; }
.qc-btn:hover { background: #f5f2ee; }
.qc-num {
    width: 46px; height: 32px;
    border: 1.5px solid #e8e4de;
    border-left: none; border-right: none;
    text-align: center;
    font-size: 13px; font-weight: 600;
    font-family: 'Inter', sans-serif;
    -moz-appearance: textfield;
}
.qc-num::-webkit-outer-spin-button,
.qc-num::-webkit-inner-spin-button { -webkit-appearance: none; }

.item-total { font-weight: 700; font-size: 15px; color: #e8500a; white-space: nowrap; min-width: 110px; text-align: right; }
.remove-btn {
    background: none; border: none;
    color: #ccc; font-size: 17px;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    transition: color .15s, background .15s;
}
.remove-btn:hover { color: #ef4444; background: #fff0f0; }

.clear-row { text-align: right; margin-top: 10px; }
.btn-clear {
    background: none; border: none;
    color: #bbb; font-size: 12px;
    cursor: pointer;
    transition: color .15s;
}
.btn-clear:hover { color: #ef4444; }

/* SUMMARY */
.cart-summary {
    background: white;
    border-radius: 14px;
    border: 1px solid #ede9e2;
    padding: 24px;
    position: sticky;
    top: 80px;
    align-self: start;
}
.summary-head { font-weight: 800; font-size: 1rem; margin-bottom: 18px; }
.sum-row { display: flex; justify-content: space-between; font-size: 13.5px; margin-bottom: 11px; color: #666; }
.sum-row.total {
    font-size: 17px; font-weight: 800; color: #111;
    border-top: 1px solid #f0ede8;
    padding-top: 13px; margin-top: 6px;
}
.sum-row.total span:last-child { color: #e8500a; }
.ship-note {
    font-size: 12px;
    text-align: center;
    padding: 9px 12px;
    border-radius: 8px;
    margin: 12px 0;
}
.ship-free { background: #f0fff4; color: #16a34a; }
.ship-hint { background: #fff8f0; color: #e8500a; }
.btn-checkout {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; height: 50px;
    background: #e8500a; color: white; border: none;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 14px; font-weight: 700;
    cursor: pointer; transition: background .18s;
    text-decoration: none;
    margin-top: 4px;
}
.btn-checkout:hover { background: #ff6b2b; color: white; }
.btn-continue {
    display: block; text-align: center;
    color: #aaa; font-size: 13px;
    text-decoration: none; margin-top: 12px;
    transition: color .15s;
}
.btn-continue:hover { color: #e8500a; }

/* EMPTY */
.empty-cart {
    text-align: center;
    background: white;
    border-radius: 14px;
    border: 1px solid #ede9e2;
    padding: 80px 40px;
}
.empty-icon { font-size: 60px; margin-bottom: 16px; }

@@media (max-width: 900px) {
    .cart-layout { grid-template-columns: 1fr; }
    .cart-summary { position: static; }
    .cart-page { padding: 0 16px 40px; }
    .cart-row { grid-template-columns: 72px 1fr; gap: 12px; }
    .item-total, .remove-btn { grid-column: 2; }
    .qty-ctrl { grid-column: 2; }
}
</style>
}

<div class="cart-page">
    <h1 class="page-title">
        GIỎ <span>HÀNG</span>
        <small style="font-size:.9rem;color:#aaa;font-weight:400;letter-spacing:0">
            (@Model.TotalQuantity sản phẩm)
        </small>
    </h1>

    @if (!Model.Items.Any())
    {
        <div class="empty-cart">
            <div class="empty-icon">🛒</div>
            <h4 style="font-weight:800;margin-bottom:8px">Giỏ hàng trống</h4>
            <p style="color:#aaa;margin-bottom:24px">Hãy thêm sản phẩm vào giỏ hàng nhé!</p>
            <a asp-controller="Shop" asp-action="Index"
               style="background:#e8500a;color:white;padding:11px 28px;
                      border-radius:9px;text-decoration:none;font-weight:700;font-size:14px">
                Mua sắm ngay →
            </a>
        </div>
    }
    else
    {
        <div class="cart-layout">

            <!-- Items -->
            <div>
                <div class="cart-table">
                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-row">
                            <!-- Ảnh -->
                            <div class="cart-thumb">
                                <img src="@(string.IsNullOrEmpty(item.ProductImage) ? "/images/no-image.png" : item.ProductImage)"
                                     alt="@item.ProductName" />
                            </div>

                            <!-- Tên + meta -->
                            <div>
                                <div class="item-name">@item.ProductName</div>
                                <div class="item-meta">
                                    @if (!string.IsNullOrEmpty(item.Size))
                                    { <span class="item-tag">Size EU @item.Size</span> }
                                    @if (!string.IsNullOrEmpty(item.Color))
                                    { <span class="item-tag">@item.Color</span> }
                                </div>
                                <div class="item-unit">@item.UnitPrice.ToString("N0") ₫ / đôi</div>
                            </div>

                            <!-- Qty -->
                            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="hidden" name="size"      value="@item.Size" />
                                <input type="hidden" name="color"     value="@item.Color" />
                                <div class="qty-ctrl">
                                    <button type="button" class="qc-btn"
                                            onclick="stepQty(this,-1)">−</button>
                                    <input type="number" class="qc-num" name="quantity"
                                           value="@item.Quantity" min="1"
                                           onchange="this.form.submit()" />
                                    <button type="button" class="qc-btn"
                                            onclick="stepQty(this,1)">+</button>
                                </div>
                            </form>

                            <!-- Subtotal -->
                            <div class="item-total">@item.TotalPrice.ToString("N0") ₫</div>

                            <!-- Remove -->
                            <form asp-controller="Cart" asp-action="RemoveItem" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="hidden" name="size"      value="@item.Size" />
                                <input type="hidden" name="color"     value="@item.Color" />
                                <button type="submit" class="remove-btn" title="Xoá">
                                    <i class="fas fa-xmark"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>

                <div class="clear-row">
                    <form asp-controller="Cart" asp-action="ClearCart" method="post"
                          onsubmit="return confirm('Xoá toàn bộ giỏ hàng?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-clear">
                            <i class="fas fa-trash-can"></i> Xoá tất cả
                        </button>
                    </form>
                </div>
            </div>

            <!-- Summary -->
            <div class="cart-summary">
                <div class="summary-head">Tổng đơn hàng</div>

                <div class="sum-row">
                    <span>Tạm tính</span>
                    <span>@Model.TotalAmount.ToString("N0") ₫</span>
                </div>
                <div class="sum-row">
                    <span>Phí vận chuyển</span>
                    <span>@(Model.ShippingFee == 0 ? "Miễn phí" : Model.ShippingFee.ToString("N0") + " ₫")</span>
                </div>

                @if (Model.ShippingFee == 0)
                {
                    <div class="ship-note ship-free">
                        🎉 Bạn được miễn phí vận chuyển!
                    </div>
                }
                else
                {
                    var need = 500_000 - Model.TotalAmount;
                    <div class="ship-note ship-hint">
                        Mua thêm @need.ToString("N0") ₫ để được miễn phí ship
                    </div>
                }

                <div class="sum-row total">
                    <span>Tổng cộng</span>
                    <span>@Model.GrandTotal.ToString("N0") ₫</span>
                </div>

                <a asp-controller="Checkout" asp-action="Index" class="btn-checkout">
                    <i class="fas fa-lock"></i> Thanh toán →
                </a>
                <a asp-controller="Shop" asp-action="Index" class="btn-continue">
                    ← Tiếp tục mua sắm
                </a>
            </div>

        </div>
    }
</div>

@section Scripts {
<script>
function stepQty(btn, delta) {
    const inp = btn.parentElement.querySelector('.qc-num');
    let v = parseInt(inp.value) + delta;
    if (v < 1) v = 1;
    inp.value = v;
    inp.form.submit();
}
</script>
}
